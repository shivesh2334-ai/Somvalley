
# Create the vercel.json configuration file
vercel_config = '''{
  "version": 2,
  "name": "somvalley-play-school",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}'''

with open('/mnt/agents/output/vercel.json', 'w') as f:
    f.write(vercel_config)

